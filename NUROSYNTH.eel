currentA = -1;
currentB = -1;
compoundTransition = 1.0;
transitionSpeed = 0.02;

baseTwitchFreq = 25;
baseGlowFreq = 10;
baseVoidFreq = 2;
baseHeartRate = 70;

targetHeartRate = 70;
targetTwitchFreq = 25;
targetTwitchVal = 0;
targetGlowFreq = 10;
targetGlowVal = 0;
targetVoidFreq = 2;
