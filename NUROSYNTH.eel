Overdrive = slider13;
OverdriveSpeed = slider14;
TactileWarning = slider15;
TheDrop = slider16;
ChromeSpecial = slider17;
EnableOverdose = slider18;
OverdoseIntensity = slider19;
AutoEscalate = slider20;
RampSpeed = slider21;

chromeActive = 0;
chromeFlash = 0;
rampStartProgress = 0.3;

delayBuffer = 0;
memset(delayBuffer, 0, delayBufferSize * 2);

time = 0;
blockCounter = 0;
srate = 44100;
srMs = srate / 1000;

autoProgress = 0;
manualProgress = 0;
sessionProgress = 0;
phaseProgress = 0;
curPhase = 0;
